---
/*
  The hero bar — 24 molded squares, CONCHE embossed one letter per square
  across the second row, and the bottom-right pieces snapped clean off.
  The snap itself is the load moment: CSS moves .snap-piece from attached
  to snapped ~1s after the title rises (see global.css / index script).
  Without JS — and under prefers-reduced-motion — the bar renders already
  snapped: one static, finished frame.
*/
const COLS = 6, ROWS = 4;
const X0 = 50, Y0 = 40, W = 66, H = 62, GAP = 6;
const letters = ['C', 'O', 'N', 'C', 'H', 'E'];

const cells = [];
for (let r = 0; r < ROWS; r++)
  for (let c = 0; c < COLS; c++)
    cells.push({ c, r, x: X0 + c * (W + GAP), y: Y0 + r * (H + GAP) });

const inChunk = (cell) => cell.c === 5 && cell.r >= 2;   // bottom-right 1×2 chunk
const barCells = cells.filter((c) => !inChunk(c));
const chunkCells = cells.filter(inChunk);

const seg = (cell) => ({ x: cell.x, y: cell.y });
---
<svg
  class="hero-bar-svg"
  viewBox="0 0 560 380"
  role="img"
  aria-label="A dark chocolate bar of twenty-four molded squares, CONCHE embossed across its second row, with the two bottom-right squares snapped cleanly off, gold foil showing beneath the break"
>
  <defs>
    <linearGradient id="hbg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="var(--choc-hi)" />
      <stop offset=".55" stop-color="var(--choc)" />
      <stop offset="1" stop-color="var(--choc-lo)" />
    </linearGradient>
  </defs>

  <!-- wrapper peeking out behind the bar -->
  <g transform="rotate(-4 118 195)" aria-hidden="true">
    <rect x="26" y="66" width="190" height="256" rx="6" fill="var(--panel)" stroke="var(--line)" stroke-width="1.5" />
    <rect x="26" y="66" width="190" height="34" rx="6" fill="var(--gold)" opacity=".85" />
  </g>

  <ellipse cx="270" cy="330" rx="230" ry="15" fill="var(--bar-shadow)" opacity=".5" aria-hidden="true" />

  <!-- gold foil revealed where the chunk snapped away -->
  <rect x="412" y="178" width="64" height="126" rx="7" fill="var(--gold)" opacity=".28" aria-hidden="true" />

  <!-- the bar -->
  <g aria-hidden="true">
    {barCells.map((cell) => (
      <>
        <rect x={cell.x} y={cell.y} width={W} height={H} rx="7" fill="url(#hbg)" stroke="var(--choc-lo)" stroke-width="1.5" />
        <rect x={cell.x + 4} y={cell.y + 4} width={W - 8} height={H - 8} rx="5" fill="none" stroke="var(--choc-hi)" stroke-width="1.4" opacity=".55" />
      </>
    ))}
    {letters.map((L, i) => (
      <>
        <text x={X0 + i * (W + GAP) + W / 2 + 1} y={Y0 + 1 * (H + GAP) + H / 2 + 11.5}
          text-anchor="middle" font-size="30" fill="var(--choc-hi)"
          style="font-family: var(--font-d)">{L}</text>
        <text x={X0 + i * (W + GAP) + W / 2} y={Y0 + 1 * (H + GAP) + H / 2 + 10}
          text-anchor="middle" font-size="30" fill="var(--choc-lo)"
          style="font-family: var(--font-d)">{L}</text>
      </>
    ))}
  </g>

  <!-- the snapped chunk -->
  <g class="snap-piece" aria-hidden="true">
    {chunkCells.map((cell) => (
      <>
        <rect x={seg(cell).x} y={seg(cell).y} width={W} height={H} rx="7" fill="url(#hbg)" stroke="var(--choc-lo)" stroke-width="1.5" />
        <rect x={seg(cell).x + 4} y={seg(cell).y + 4} width={W - 8} height={H - 8} rx="5" fill="none" stroke="var(--choc-hi)" stroke-width="1.4" opacity=".55" />
      </>
    ))}
    <!-- crumbs travel with the piece -->
    <path d="M404 314 l7 -4 l3 7 l-8 3 Z" fill="var(--choc)" />
    <circle cx="392" cy="322" r="3" fill="var(--choc-lo)" />
  </g>

  <!-- the snap, made visible -->
  <g aria-hidden="true" stroke="var(--gold)" stroke-width="3.5" stroke-linecap="round">
    <line class="tick k1" x1="486" y1="158" x2="502" y2="142" />
    <line class="tick k2" x1="498" y1="180" x2="518" y2="172" />
    <line class="tick k3" x1="492" y1="200" x2="512" y2="200" />
  </g>
</svg>
